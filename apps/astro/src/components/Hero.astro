---
import { Cpu, ArrowRight, Play } from '@lucide/astro';
---

<div class="relative min-h-screen bg-slate-950 text-slate-100 flex flex-col justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#0d1f1c_1px,transparent_1px),linear-gradient(to_bottom,#0d1f1c_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"/>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-30 pb-16 text-center z-10">

        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#39b39b]/10 border border-[#39b39b]/20 text-[#39b39b] text-sm font-medium mb-6 animate-fade-in">
            <Cpu class="w-4 h-4 text-[#39b39b]"/>
            <span>React Flow Nodes v1.0 Pre-release</span>
        </div>

        <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-100 to-[#39b39b] max-w-4xl mx-auto leading-tight">
            Visualize complex logic with drag-and-drop simplicity
        </h1>

        <p>
        A powerful canvas for building interactive nodes and connections. Design complex workflows, manage
        application data, and automate processes on the fly.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
            <button class="w-full sm:w-auto flex items-center justify-center gap-2 bg-gradient-to-r from-[#39b39b] to-teal-600 hover:from-[#45cbb0] hover:to-teal-500 text-slate-950 font-bold px-8 py-4 rounded-xl shadow-lg shadow-[#39b39b]/20 transition-all duration-200 transform hover:-translate-y-0.5 cursor-pointer">
                Get Started
                <ArrowRight class="w-5 h-5 text-slate-950"/>
            </button>

            <button class="w-full sm:w-auto flex items-center justify-center gap-2 bg-slate-900 border border-slate-800 hover:bg-slate-800/80 hover:border-slate-700 text-slate-300 font-semibold px-8 py-4 rounded-xl transition-all duration-200 cursor-pointer">
                <Play class="w-4 h-4 text-slate-400 fill-slate-400"/>
                Watch Demo
            </button>
        </div>

        <div class="mt-16 relative mx-auto max-w-5xl rounded-2xl border border-slate-800 bg-slate-900/50 p-4 backdrop-blur-xl shadow-2xl">
            <div class="flex items-center justify-between border-b border-slate-800 pb-3 mb-4">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-red-500/80"/>
                    <span class="w-3 h-3 rounded-full bg-yellow-500/80"/>
                    <span class="w-3 h-3 rounded-full bg-green-500/80"/>
                    <span class="text-xs text-slate-500 font-mono ml-2">flow_workspace_main.json</span>
                </div>
                <div class="text-xs bg-slate-800 text-slate-400 px-2 py-1 rounded font-mono">
                    Nodes: 12 | Edges: 15
                </div>
            </div>

            <div class="h-100 rounded-lg bg-slate-950/80 flex items-center justify-center border border-slate-800/50 relative overflow-hidden">
            </div>
        </div>

    </div>
</div>
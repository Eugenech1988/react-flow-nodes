---
import { Check, HelpCircle } from '@lucide/astro';

const tiers = [
    {
        name: "Hobby",
        price: "$0",
        description: "Perfect for personal projects, side hustles, and experimenting with visual workflows.",
        features: [
            "Up to 3 active workflows",
            "1,000 executions per month",
            "Standard edge routing (500ms SLA)",
            "Community support via Discord",
            "1-day execution history retention"
        ],
        cta: "Start for Free",
        href: "#",
        popular: false
    },
    {
        name: "Pro",
        price: "$49",
        period: "/mo",
        description: "For production-grade applications needing high performance, scale, and advanced features.",
        features: [
            "Unlimited active workflows",
            "50,000 executions included",
            "Ultra-low latency routing (< 15ms SLA)",
            "Priority Slack & Email support (24h)",
            "30-day execution history retention",
            "Custom webhooks and API payloads",
            "Advanced error handling & retries"
        ],
        cta: "Upgrade to Pro",
        href: "#",
        popular: true
    },
    {
        name: "Enterprise",
        price: "Custom",
        description: "Tailored infrastructure, dedicated runners, and strict security compliance for teams.",
        features: [
            "Unlimited executions and workflows",
            "Dedicated, isolated edge instances",
            "99.99% uptime SLA guarantee",
            "Dedicated Account Manager (24/7/365)",
            "Unlimited history retention",
            "SSO / SAML authentication",
            "Custom security event logging"
        ],
        cta: "Contact Sales",
        href: "#",
        popular: false
    }
];
---

<section class="relative py-20 bg-slate-950 overflow-hidden border-t border-slate-900">
    {/* Декоративное фоновое свечение за самым популярным тарифом */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/3 w-[500px] h-[500px] bg-teal-500/5 rounded-full blur-3xl pointer-events-none" />

    <div class="max-w-5xl mx-auto px-6 relative z-10">

        {/* Заголовок секции с градиентом */}
        <div class="text-center max-w-2xl mx-auto mb-16">
            <span class="text-xs font-mono font-bold text-teal-400 uppercase tracking-widest bg-teal-500/10 px-3 py-1 rounded-full">
                Pricing Plans
            </span>
            <h2 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight bg-clip-text text-transparent bg-linear-to-r from-white via-slate-100 to-teal-400">
                Simple, Fair Pricing
            </h2>
            <p class="mt-4 text-base text-slate-400">
                No hidden servers. No infrastructure overhead. Choose a plan that scales instantly with your business demands.
            </p>
        </div>

        {/* Сетка тарифов */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
            {tiers.map((tier) => (
                <div class={`relative rounded-2xl p-6 transition-all duration-300 flex flex-col justify-between h-full ${
                    tier.popular 
                        ? 'bg-slate-900/80 border-2 border-teal-500/40 shadow-[0_0_30px_var(--color-teal-500/5)] md:-translate-y-4 scale-102 z-10' 
                        : 'bg-slate-900/40 border border-slate-800 hover:border-slate-700 backdrop-blur-md'
                }`}>

                    {/* Бейдж популярного тарифа */}
                    {tier.popular && (
                        <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-0.5 bg-teal-400 text-slate-950 text-[10px] font-mono font-bold rounded-full uppercase tracking-wider">
                            Most Popular
                        </span>
                    )}

                    <div>
                        {/* Шапка тарифа */}
                        <div class="mb-6">
                            <h3 class="text-lg font-bold text-slate-200">{tier.name}</h3>
                            <div class="mt-4 flex items-baseline gap-1">
                                <span class="text-4xl font-extrabold text-slate-100 tracking-tight">{tier.price}</span>
                                {tier.period && (
                                    <span class="text-xs text-slate-500 font-mono">{tier.period}</span>
                                )}
                            </div>
                            <p class="mt-3 text-xs text-slate-400 leading-relaxed min-h-[48px]">
                                {tier.description}
                            </p>
                        </div>

                        {/* Список фичей */}
                        <ul class="space-y-3.5 border-t border-slate-800/80 pt-6 mb-8">
                            {tier.features.map((feature) => (
                                <li class="flex items-start gap-3">
                                    <div class="mt-0.5 p-0.5 bg-teal-500/10 rounded-full text-teal-400 shrink-0">
                                        <Check class="w-3.5 h-3.5" />
                                    </div>
                                    <span class="text-xs text-slate-300 leading-normal">{feature}</span>
                                </li>
                            ))}
                        </ul>
                    </div>

                    {/* Кнопка действия */}
                    <a
                        href={tier.href}
                        class={`w-full py-2.5 rounded-xl text-xs font-bold text-center transition-all cursor-pointer ${
                            tier.popular
                                ? 'bg-teal-400 text-slate-950 hover:bg-teal-350 shadow-md shadow-teal-500/10'
                                : 'bg-slate-800 text-slate-200 hover:bg-slate-700 border border-slate-700'
                        }`}
                    >
                        {tier.cta}
                    </a>
                </div>
            ))}
        </div>

        {/* Дополнительный блок FAQ / Примечание */}
        <div class="mt-16 text-center flex items-center justify-center gap-2 text-xs text-slate-500 font-mono">
            <HelpCircle class="w-4 h-4 text-teal-400" />
            <span>Have questions about high-volume usage? <a href="#contact" class="text-teal-400 hover:underline">Chat with our engineers</a></span>
        </div>

    </div>
</section>
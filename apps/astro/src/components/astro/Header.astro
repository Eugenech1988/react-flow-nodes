---
import piplineLogo from '@/assets/logo.svg?raw';

interface Link {
    text: string;
    href: string;
}

const navLinks: Link[] = [
    { text: 'Platform', href: '#platform' },
    { text: 'Solutions', href: '#solutions' },
    { text: 'Templates', href: '#templates' },
    { text: 'Docs', href: '#docs' },
    { text: 'Pricing', href: '#pricing' }
];
---

<header class="fixed top-4 left-1/2 z-50 w-[95%] max-w-7xl -translate-x-1/2 transition-all duration-300">
    <div class="relative w-full rounded-2xl border border-white/10 bg-white/6 px-6 py-3 shadow-[0_8px_32px_0_rgba(0,0,0,0.2)] backdrop-blur-md after:absolute after:inset-0 after:-z-10 after:rounded-2xl after:bg-linear-to-b after:from-white/5 after:to-transparent after:opacity-50">
        <div class="flex items-center justify-between">

            <a href="/" class="group flex items-center gap-2.5 text-white font-semibold text-lg tracking-tight">
                <div class="h-6 w-6 flex items-center justify-center text-teal-400 transition-transform duration-300 group-hover:scale-110">
                    <Fragment set:html={piplineLogo}/>
                </div>
                <span class="bg-linear-to-r from-white via-neutral-100 to-[#39b39b] bg-clip-text text-transparent font-medium transition-colors duration-300">
                    pipeline studio
                </span>
            </a>

            <nav class="hidden md:flex items-center gap-1">
                {navLinks.map((link) => (
                  <a
                    href={link.href}
                    class="rounded-lg px-4 py-2 text-sm text-neutral-300 transition-colors hover:bg-white/5 hover:text-white"
                  >
                      {link.text}
                  </a>
                ))}
            </nav>

            <div class="hidden md:flex items-center gap-4">
                <a href="/login" class="text-sm font-medium text-neutral-300 transition-colors hover:text-white">
                    Sign in
                </a>
                <a
                  href="/start"
                  class="relative overflow-hidden rounded-xl bg-white px-4 py-1.5 text-xs font-semibold text-neutral-950 transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(57,179,155,0.4)]"
                >
                    Get started
                </a>
            </div>

            <button
              id="mobile-menu-btn"
              class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 text-white hover:bg-white/5 md:hidden"
              aria-label="Toggle Menu"
            >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
                </svg>
            </button>

        </div>

        <div
          id="mobile-menu"
          class="grid grid-rows-[0fr] opacity-0 pointer-events-none mt-0 transition-[grid-template-rows,opacity,margin-top] duration-300 ease-in-out rounded-xl border border-white/5 bg-black/40 backdrop-blur-lg md:hidden"
        >
            <div class="overflow-hidden">
                <div class="p-4 flex flex-col gap-2">
                    {navLinks.map((link) => (
                      <a
                        href={link.href}
                        class="block rounded-lg px-3 py-2 text-base text-neutral-300 hover:bg-white/5 hover:text-white"
                      >
                          {link.text}
                      </a>
                    ))}
                    <hr class="my-2 border-white/10"/>
                    <div class="flex flex-col gap-3 pt-2">
                        <a href="/login" class="text-center text-sm font-medium text-neutral-300 hover:text-white">
                            Sign in
                        </a>
                        <a
                          href="/start"
                          class="rounded-xl bg-white py-2.5 text-center text-sm font-semibold text-neutral-950 transition-all duration-300 hover:bg-neutral-100"
                        >
                            Get started
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</header>

<style is:global>
    /* Принудительно заставляем внутренние пути SVG наследовать цвет текста (currentColor) */
    .group svg path,
    .group svg rect,
    .group svg circle {
        stroke: currentColor !important;
        /* Если в вашем SVG используется заливка вместо обводки, раскомментируйте строку ниже: */
        /* fill: currentColor !important; */
    }
</style>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn && menu) {
        btn.addEventListener('click', () => {
            // Переключаем высоту сетки (0fr -> 1fr)
            menu.classList.toggle('grid-rows-[0fr]');
            menu.classList.toggle('grid-rows-[1fr]');

            // Переключаем прозрачность
            menu.classList.toggle('opacity-0');
            menu.classList.toggle('opacity-100');

            // Переключаем верхний отступ
            menu.classList.toggle('mt-0');
            menu.classList.toggle('mt-4');

            // Переключаем кликабельность ссылок
            menu.classList.toggle('pointer-events-none');
            menu.classList.toggle('pointer-events-auto');
        });
    }
</script>